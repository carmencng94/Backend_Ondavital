# ========================================
# CONFIGURACIÓN DE CHAT - PROVEEDORES IA
# ========================================

# Proveedor principal de IA (exclusivo: openrouter o openai)
CHAT_PROVIDER=openrouter
# Proveedor fallback si falla el principal
CHAT_FALLBACK=none

# ========================================
# CONFIGURACIÓN DE OPENROUTER
# ========================================
OPENROUTER_API_KEY="tu_clave_de_api_de_openrouter"
# Modelos recomendados y económicos en orden de fallback (separados por comas)
OPENROUTER_MODEL="google/gemini-2.5-flash-lite,meta-llama/llama-3.3-70b-instruct,deepseek/deepseek-chat,meta-llama/llama-3.1-8b-instruct:free"
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_MAX_TOKENS=2048
OPENROUTER_REFERER=https://ondavital.com

# ========================================
# CONFIGURACIÓN DE GROK (xAI)
# ========================================
XAI_API_KEY="tu_clave_de_api_de_grok"
GROK_API_KEY="tu_clave_de_api_de_grok"
GROK_MODEL=grok-4.1-fast
GROK_TEMPERATURE=0.7
GROK_MAX_TOKENS=2048

# ========================================
# CONFIGURACIÓN DE OPENAI
# ========================================
OPENAI_API_KEY="tu_clave_de_api_de_openai"
OPENAI_MODEL=gpt-4-turbo
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2048

# ========================================
# CONFIGURACIÓN DE BASE DE DATOS Y SEGURIDAD
# ========================================
DB_PATH="./memory.db"
# Clave secreta larga para firmar JWT tokens
JWT_SECRET="genera_una_clave_secreta_jwt_segura_y_larga"
# Clave AES de 32 bytes en formato hex para encriptación de datos sensibles de contacto
AES_SECRET_KEY="genera_una_clave_aes_de_32_bytes_en_hex_64_caracteres"

# ========================================
# CONFIGURACIÓN DEL PANEL DE ADMINISTRACIÓN
# ========================================
ADMIN_USER=admin
ADMIN_PASSWORD=cambia_esta_contraseña_inmediatamente

# ========================================
# CONFIGURACIÓN DEL SERVIDOR
# ========================================
PORT=3051
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3051,http://127.0.0.1:3051

# ========================================
# INTEGRACIONES EXTERNAS (OPCIONALES)
# ========================================
GOOGLE_CALENDAR_ID="tu_google_calendar_id@group.calendar.google.com"
RASA_LICENSE="tu_licencia_de_rasa_si_aplica"
